# 智能报价系统 - 测试环境配置
# 部署脚本会自动加载此文件：./scripts/deploy.sh staging

# ---------- PostgreSQL ----------
POSTGRES_DB=ai_quote_staging
POSTGRES_USER=ai_quote_user
POSTGRES_PASSWORD=CHANGE_ME_staging_password_2024

# ---------- 后端 ----------
JWT_SECRET_KEY=CHANGE_ME_staging_jwt_secret
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_QUOTE_MODEL=qwen:latest

# ---------- 前端构建 ----------
VITE_API_BASE_URL=/api
VITE_BAIDU_MAP_AK=

# ---------- 对外端口 ----------
FRONTEND_PORT=8080

# ---------- 镜像版本 ----------
IMAGE_TAG=latest
GHCR_IMAGE_BACKEND=ghcr.io/zeeeelatan/ai-quote-backend
GHCR_IMAGE_FRONTEND=ghcr.io/zeeeelatan/ai-quote-frontend
