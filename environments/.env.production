# 智能报价系统 - 正式环境配置
# 部署脚本会自动加载此文件：./scripts/deploy.sh production v1.x.x
#
# !! 重要：部署前必须修改所有 CHANGE_ME 项 !!

# ---------- PostgreSQL ----------
POSTGRES_DB=ai_quote_prod
POSTGRES_USER=ai_quote_user
POSTGRES_PASSWORD=CHANGE_ME_use_strong_random_password

# ---------- 后端 ----------
JWT_SECRET_KEY=CHANGE_ME_use_strong_random_jwt_secret
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_QUOTE_MODEL=qwen:latest

# ---------- 前端构建 ----------
VITE_API_BASE_URL=/api
VITE_BAIDU_MAP_AK=

# ---------- 对外端口 ----------
# 生产环境由宿主机 nginx 反向代理，Docker 容器映射到 8080
FRONTEND_PORT=8080

# ---------- 镜像版本 ----------
IMAGE_TAG=CHANGE_ME_set_release_version
GHCR_IMAGE_BACKEND=ghcr.io/zeeeelatan/ai-quote-backend
GHCR_IMAGE_FRONTEND=ghcr.io/zeeeelatan/ai-quote-frontend
