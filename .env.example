# 智能报价系统 Docker 部署 - 环境变量示例
# 使用前：复制本文件为 .env 并按需修改（不要将 .env 提交到版本库）

# ---------- PostgreSQL（与 backend/app/database.py 一致） ----------
POSTGRES_DB=device_inventory_ai_quote_test
POSTGRES_USER=device_inventory_user
POSTGRES_PASSWORD=change_me_password

# ---------- 后端 ----------
# 生产环境务必改为随机强密钥
JWT_SECRET_KEY=dev-secret-change-in-production

# 阿里云百炼 AI 大模型（推荐，正式环境使用）
# 获取 API Key：https://bailian.console.aliyun.com/ → API-KEY 管理
DASHSCOPE_API_KEY=
DASHSCOPE_MODEL=qwen-plus

# Ollama 本地模型（开发环境备用，配置了 DASHSCOPE_API_KEY 时自动忽略）
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_QUOTE_MODEL=qwen:latest

# ---------- 前端构建（构建时注入，浏览器请求 API 的基地址） ----------
# 与 nginx 代理一致时使用 /api；若前后端同域则填 /api
VITE_API_BASE_URL=/api
# 可选：高德地图 Key，用于搬迁路径配置等地图功能
VITE_AMAP_KEY=
# 高德地图安全密钥（2021.12 后创建的 Key 必须配置）
VITE_AMAP_SECURITY_KEY=

# ---------- 对外端口 ----------
# 前端 nginx 映射到宿主机的端口，默认 80
FRONTEND_PORT=80

# ---------- 生产/发布（仅在使用 docker-compose.prod.yml 时需要） ----------
# 镜像版本，用于发布与回滚（与 CI 打出的 tag 一致，如 v1.0.0、sha-abc1234）
# IMAGE_TAG=latest
# GHCR 镜像地址（将 REPLACE_OWNER 改为你的 GitHub 用户名或组织名）
# GHCR_IMAGE_BACKEND=ghcr.io/REPLACE_OWNER/ai-quote-backend
# GHCR_IMAGE_FRONTEND=ghcr.io/REPLACE_OWNER/ai-quote-frontend
